# =============================================================================
# Agentic Log Analytics — .gitignore
# =============================================================================

# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Never ignore .env.example — it documents required variables

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
*.so

# ─── Go ───────────────────────────────────────────────────────────────────────
# Compiled binaries (all platforms)
*.exe
*.exe~
*.dll
*.dylib
# Go binary outputs (service binaries built locally)
services/log-ingestion/server
services/log-consumer/server
# Go test artifacts
*.test
*.out
# Go workspace (not used here but prevent accidental commits)
go.work
go.work.sum
# Vendor directory (we use go modules)
vendor/

# ─── Node / React UI ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
services/ui/dist/
services/ui/build/
services/ui/.next/

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
*.iml
.settings/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ─── Docker ───────────────────────────────────────────────────────────────────
# Never commit local Docker volume data
infra/postgres/data/
infra/redis/data/
infra/chromadb/data/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Test artifacts ───────────────────────────────────────────────────────────
.pytest_cache/
test-results/
coverage.xml
junit.xml
