# =============================================================================
# Agentic Log Analytics — Environment Variables Reference
#
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# All services read their subset of these variables.
# Fail-fast validation at startup: missing required vars = service won't start.
# =============================================================================

# =============================================================================
# SHARED — used by multiple services
# =============================================================================

# PostgreSQL connection string.
# Services use this with options=-c timezone=UTC appended.
POSTGRES_URL=postgresql://admin:admin@localhost:5432/loganalytics

# Kafka broker(s). Comma-separated for multi-broker clusters.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis connection string. Used by semantic cache and anomaly baselines.
REDIS_URL=redis://localhost:6379

# ChromaDB HTTP URL. Used by anomaly detection and RCA hybrid RAG.
CHROMADB_URL=http://localhost:8081

# Structured log level: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# =============================================================================
# OPENAI / LLM
# =============================================================================

# OpenAI API key. Required by anomaly detection, context compressor,
# semantic cache (embeddings), RCA agent, and evaluation harness.
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# SECURITY MIDDLEWARE (:8083)
# =============================================================================

# Kafka topic to consume raw logs from.
SECURITY_INPUT_TOPIC=logs.raw

# Kafka topic for clean (post-scan) logs.
SECURITY_OUTPUT_TOPIC=logs.raw.clean

# Kafka topic for security events (injections, PII detections).
SECURITY_EVENTS_TOPIC=security.events

# Kafka consumer group ID for security middleware.
SECURITY_CONSUMER_GROUP=security-middleware-group

# =============================================================================
# LOG CONSUMER (Go) (:8084)
# =============================================================================

# Kafka topic to consume clean logs from.
LOG_CONSUMER_INPUT_TOPIC=logs.raw.clean

# Kafka topic to publish enriched logs to after DB insert.
LOG_CONSUMER_OUTPUT_TOPIC=logs.enriched

# Kafka topic for failed messages after 3 retries.
LOG_CONSUMER_DLQ_TOPIC=logs.dlq

# Kafka consumer group ID.
LOG_CONSUMER_GROUP=log-consumer-group

# Batch size: flush when this many logs accumulated.
LOG_CONSUMER_BATCH_SIZE=100

# Batch timeout: flush after this many seconds even if batch not full.
LOG_CONSUMER_BATCH_TIMEOUT_SECONDS=5

# =============================================================================
# ANOMALY DETECTION AGENT (:8085)
# =============================================================================

# Z-score threshold above which error-rate spike is flagged as anomaly.
# 3.0 = flag if current value is 3 standard deviations above baseline.
ZSCORE_THRESHOLD=3.0

# Cosine similarity threshold below which an embedding is classed as novel.
# 0.7 = flag error if it is less than 70% similar to anything seen before.
SIMILARITY_THRESHOLD=0.7

# Set to true to skip LLM verification for LOW severity anomalies.
# Reduces token cost at the expense of more false positives.
LOW_SKIP=false

# Kafka consumer group ID for anomaly agent.
ANOMALY_CONSUMER_GROUP=anomaly-agent-group

# =============================================================================
# ALERT CORRELATION ENGINE (:8086)
# =============================================================================

# Sliding window duration in seconds. Alerts within this window are grouped
# into a CascadeIncident when they span multiple services.
CORRELATION_WINDOW_SECONDS=60

# Kafka consumer group ID.
CORRELATION_CONSUMER_GROUP=alert-correlator-group

# =============================================================================
# CONTEXT COMPRESSOR (:8087)
# =============================================================================

# Token count above which log context is compressed before RCA.
# GPT-4 context window is 128k; 6000 leaves room for the prompt + response.
COMPRESSION_TOKEN_THRESHOLD=6000

# Number of recent log lines to fetch per affected service.
LOG_FETCH_LIMIT=500

# Kafka consumer group ID.
COMPRESSOR_CONSUMER_GROUP=context-compressor-group

# =============================================================================
# SEMANTIC CACHE (:8088)
# =============================================================================

# Cosine similarity threshold above which a prior result is returned from cache.
# 0.92 = 92% similar incidents reuse the prior RCA without calling the LLM.
CACHE_SIMILARITY_THRESHOLD=0.92

# Cache entry TTL in seconds. Default: 24 hours.
CACHE_TTL_SECONDS=86400

# Kafka consumer group ID.
CACHE_CONSUMER_GROUP=semantic-cache-group

# =============================================================================
# MODEL ROUTER (:8089)
# =============================================================================

# Model to use when tenant daily budget is exhausted.
# Overrides the severity-based routing to prevent runaway spend.
DAILY_BUDGET_OVERRIDE_MODEL=gpt-3.5-turbo

# Kafka consumer group ID.
ROUTER_CONSUMER_GROUP=model-router-group

# =============================================================================
# RCA AGENT (:8090)
# =============================================================================

# Minimum confidence score for an RCA result to be accepted.
# Below this: routed to rca.dlq with reason=low_confidence.
CONFIDENCE_THRESHOLD=0.8

# Maximum ReAct loop iterations before giving up.
# Prevents runaway LLM usage on pathological inputs.
MAX_ITERATIONS=15

# Kafka consumer group ID.
RCA_CONSUMER_GROUP=rca-agent-group

# =============================================================================
# EVALUATION HARNESS (:8091)
# =============================================================================

# Enable automatic knowledge base indexing of high-quality RCA results.
# Only indexes when eval_mode=ground_truth AND faithfulness>0.8 AND hallucination>0.7.
AUTO_LEARN=false

# Kafka consumer group ID.
EVAL_CONSUMER_GROUP=eval-harness-group

# =============================================================================
# SLACK NOTIFIER
# =============================================================================

# Slack incoming webhook URL. Required for CRITICAL alert notifications.
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =============================================================================
# API GATEWAY (:8000)
# =============================================================================

# Internal URL for the log ingestion service (used for proxy).
LOG_INGESTION_URL=http://localhost:8082

# How long to cache resolved API key → tenant mappings in memory.
API_KEY_CACHE_TTL_SECONDS=60

# =============================================================================
# INFRASTRUCTURE (docker-compose internal values — not needed in .env for prod)
# =============================================================================

POSTGRES_DB=loganalytics
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_INITDB_ARGS=--encoding=UTF8 --lc-collate=C --lc-ctype=C
